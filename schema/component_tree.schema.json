{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "profile",
    "components"
  ],
  "properties": {
    "profile": {
      "type": "string",
      "enum": [
        "strict_draftbox",
        "rich_article"
      ]
    },
    "components": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/component"
      }
    }
  },
  "$defs": {
    "component": {
      "type": "object",
      "required": [
        "type",
        "role",
        "content",
        "style_token"
      ],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "article_container",
            "title_block",
            "intro_conclusion_card",
            "problem_intro",
            "article_nav",
            "section_title",
            "body_paragraph",
            "emphasis_sentence",
            "core_quote_card",
            "auxiliary_quote",
            "insight_card",
            "step_card",
            "checklist",
            "simple_compare_table",
            "image_block",
            "image_caption",
            "divider",
            "summary_card",
            "references_block",
            "soft_cta",
            "semantic_color_block",
            "outlined_text_box",
            "left_quote",
            "capsule_label",
            "icon_marker",
            "double_compare",
            "gradient_emphasis_bar",
            "editorial_note",
            "numbered_points",
            "strong_emphasis",
            "solid_underline",
            "dotted_underline",
            "double_underline",
            "strikethrough",
            "inline_highlight",
            "text_color",
            "inline_pill",
            "inline_outline",
            "data_badge",

            "category_marker",
            "source_note",
            "citation_block",
            "article_end_mark"
          ]
        },
        "role": {
          "type": "string"
        },
        "content": {},
        "style_token": {
          "type": "string"
        },
        "children": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/component"
          }
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}

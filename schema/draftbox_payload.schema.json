{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "draftbox_payload.schema.json",
  "type": "object",
  "required": [
    "title",
    "digest",
    "content_html",
    "cover_image_brief",
    "image_asset_list",
    "validation_report",
    "publish_checklist",
    "section_visual_coverage"
  ],
  "properties": {
    "title": {
      "type": "string"
    },
    "digest": {
      "type": "string",
      "maxLength": 120
    },
    "content_html": {
      "type": "string",
      "minLength": 1,
      "not": {
        "pattern": "<\\s*(html|head|body)\\b"
      }
    },
    "cover_image_brief": {
      "type": "object"
    },
    "image_asset_list": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "usage",
          "ratio",
          "prompt",
          "placement",
          "requires_upload_to_wechat"
        ],
        "properties": {
          "usage": {
            "type": "string"
          },
          "ratio": {
            "type": "string"
          },
          "prompt": {
            "type": "string"
          },
          "placement": {
            "type": "string"
          },
          "requires_upload_to_wechat": {
            "type": "boolean"
          }
        }
      }
    },
    "validation_report": {
      "type": "object"
    },
    "publish_checklist": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "section_visual_coverage": {
      "type": "object",
      "required": [
        "status",
        "sections",
        "dry_sections",
        "single_marker_only_sections",
        "repeated_adjacent_signatures",
        "no_separator_long_sections",
        "repeated_separator_types",
        "missing_micro_symbol_sections",
        "repeated_list_symbols",
        "unused_runtime_markers",
        "decorative_symbol_overload_sections",
        "data_marker_underuse_sections",
        "quote_style_repetition",
        "runtime_marker_types"
      ],
      "properties": {
        "status": {
          "type": "string",
          "enum": [
            "pass",
            "fail"
          ]
        },
        "sections": {
          "type": "array",
          "items": {
            "type": "object"
          }
        },
        "dry_sections": {
          "type": "array",
          "items": {
            "type": "integer"
          }
        },
        "single_marker_only_sections": {
          "type": "array",
          "items": {
            "type": "integer"
          }
        },
        "repeated_adjacent_signatures": {
          "type": "array",
          "items": {
            "type": "integer"
          }
        },
        "no_separator_long_sections": {
          "type": "array",
          "items": {
            "type": "integer"
          }
        },
        "repeated_separator_types": {
          "type": "array",
          "items": {
            "type": "integer"
          }
        },
        "missing_micro_symbol_sections": {
          "type": "array",
          "items": {
            "type": "integer"
          }
        },
        "repeated_list_symbols": {
          "type": "array",
          "items": {
            "type": "integer"
          }
        },
        "unused_runtime_markers": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "decorative_symbol_overload_sections": {
          "type": "array",
          "items": {
            "type": "integer"
          }
        },
        "data_marker_underuse_sections": {
          "type": "array",
          "items": {
            "type": "integer"
          }
        },
        "quote_style_repetition": {
          "type": "boolean"
        },
        "runtime_marker_types": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    }
  }
}
